{
  "name": "image-overlay-preview",
  "displayName": "Image Overlay Preview",
  "description": "Preview images with EXIF and metadata shown as unobtrusive corner overlays — no sidebar, image stays center stage.",
  "version": "0.1.4",
  "publisher": "mcc",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e22",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcc1/vscode-image-overlay.git"
  },
  "bugs": {
    "url": "https://github.com/mcc1/vscode-image-overlay/issues"
  },
  "homepage": "https://github.com/mcc1/vscode-image-overlay#readme",
  "keywords": [
    "image",
    "preview",
    "exif",
    "metadata",
    "overlay",
    "photography",
    "viewer"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "imageOverlay.preview",
        "displayName": "Image Overlay Preview",
        "selector": [
          {
            "filenamePattern": "*.png"
          },
          {
            "filenamePattern": "*.jpg"
          },
          {
            "filenamePattern": "*.jpeg"
          },
          {
            "filenamePattern": "*.gif"
          },
          {
            "filenamePattern": "*.bmp"
          },
          {
            "filenamePattern": "*.webp"
          },
          {
            "filenamePattern": "*.avif"
          },
          {
            "filenamePattern": "*.tiff"
          },
          {
            "filenamePattern": "*.tif"
          },
          {
            "filenamePattern": "*.heic"
          },
          {
            "filenamePattern": "*.heif"
          },
          {
            "filenamePattern": "*.ico"
          },
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Image Overlay Preview",
      "properties": {
        "imageOverlay.defaultVisible": {
          "type": "boolean",
          "default": true,
          "description": "Show overlay by default when opening an image."
        },
        "imageOverlay.autoContrast": {
          "type": "boolean",
          "default": true,
          "description": "Detect background luminance under each corner and adjust overlay contrast."
        },
        "imageOverlay.showHintOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Show the keyboard shortcut hint briefly when opening an image."
        },
        "imageOverlay.gpsMapProvider": {
          "type": "string",
          "enum": [
            "openstreetmap",
            "google",
            "apple",
            "none"
          ],
          "enumDescriptions": [
            "OpenStreetMap (privacy-friendly, no Google account)",
            "Google Maps",
            "Apple Maps",
            "Do not link GPS coordinates"
          ],
          "default": "openstreetmap",
          "description": "Map service to open when clicking GPS coordinates."
        },
        "imageOverlay.browseSortBy": {
          "type": "string",
          "enum": [
            "filename",
            "mtime",
            "ctime",
            "size"
          ],
          "enumDescriptions": [
            "Filename (natural sort, case-insensitive)",
            "Last modified time",
            "Created time",
            "File size"
          ],
          "default": "filename",
          "description": "How sibling images in the same folder are ordered when browsing with arrow keys / slideshow."
        },
        "imageOverlay.browseSortOrder": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "asc",
          "description": "Sort direction for sibling images."
        },
        "imageOverlay.browseLoop": {
          "type": "boolean",
          "default": false,
          "description": "Wrap around when navigating past the first / last image (also applies to slideshow)."
        },
        "imageOverlay.slideshowIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 500,
          "description": "Default slideshow interval in milliseconds. [ and ] adjust on the fly."
        }
      }
    },
    "commands": [
      {
        "command": "imageOverlay.toggleOverlay",
        "title": "Image Overlay: Toggle Overlay"
      },
      {
        "command": "imageOverlay.toggleExpanded",
        "title": "Image Overlay: Toggle Expanded EXIF"
      }
    ],
    "keybindings": [
      {
        "command": "imageOverlay.toggleOverlay",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "activeCustomEditorId == imageOverlay.preview"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "prod": "node esbuild.mjs --prod",
    "package": "npm run prod && vsce package",
    "typecheck": "tsc --noEmit",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/utif": "^3.0.6",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "libheif-js": "^1.19.8",
    "utif": "^3.1.0"
  }
}
