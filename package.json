{
  "name": "image-overlay-preview",
  "displayName": "Image Overlay Preview",
  "description": "Preview images with EXIF and metadata shown as unobtrusive corner overlays — no sidebar, image stays center stage.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e22",
    "theme": "dark"
  },
  "keywords": [
    "image",
    "preview",
    "exif",
    "metadata",
    "overlay",
    "photography",
    "viewer"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "imageOverlay.preview",
        "displayName": "Image Overlay Preview",
        "selector": [
          { "filenamePattern": "*.png" },
          { "filenamePattern": "*.jpg" },
          { "filenamePattern": "*.jpeg" },
          { "filenamePattern": "*.gif" },
          { "filenamePattern": "*.bmp" },
          { "filenamePattern": "*.webp" },
          { "filenamePattern": "*.avif" },
          { "filenamePattern": "*.tiff" },
          { "filenamePattern": "*.tif" },
          { "filenamePattern": "*.ico" }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Image Overlay Preview",
      "properties": {
        "imageOverlay.defaultVisible": {
          "type": "boolean",
          "default": true,
          "description": "Show overlay by default when opening an image."
        },
        "imageOverlay.autoContrast": {
          "type": "boolean",
          "default": true,
          "description": "Detect background luminance under each corner and adjust overlay contrast."
        },
        "imageOverlay.showHintOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Show the keyboard shortcut hint briefly when opening an image."
        },
        "imageOverlay.gpsMapProvider": {
          "type": "string",
          "enum": ["openstreetmap", "google", "apple", "none"],
          "enumDescriptions": [
            "OpenStreetMap (privacy-friendly, no Google account)",
            "Google Maps",
            "Apple Maps",
            "Do not link GPS coordinates"
          ],
          "default": "openstreetmap",
          "description": "Map service to open when clicking GPS coordinates."
        }
      }
    },
    "commands": [
      { "command": "imageOverlay.toggleOverlay", "title": "Image Overlay: Toggle Overlay" },
      { "command": "imageOverlay.toggleExpanded", "title": "Image Overlay: Toggle Expanded EXIF" }
    ],
    "keybindings": [
      { "command": "imageOverlay.toggleOverlay", "key": "ctrl+shift+i", "mac": "cmd+shift+i", "when": "activeCustomEditorId == imageOverlay.preview" }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "prod": "node esbuild.mjs --prod",
    "icon": "node scripts/gen-icon.mjs",
    "package": "npm run prod && vsce package",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "exifr": "^7.1.3"
  }
}
